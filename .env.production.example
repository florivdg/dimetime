# DimeTime Production Environment Configuration
# Copy this file to .env and fill in your values

# Domain for Traefik routing (without protocol)
DOMAIN=dimetime.flori.cloud

# Authentication secret - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Full URL of your application (with https://)
BETTER_AUTH_URL=https://${DOMAIN}

# WebAuthn/Passkey configuration
# RP_ID is your domain without protocol
PASSKEY_RP_ID=${DOMAIN}
# Origin is your full URL with protocol
PASSKEY_ORIGIN=https://${DOMAIN}

# Enable Banking (optional) – leave empty to disable the integration
# Get APP_ID and download the private key at https://enablebanking.com/cp/applications
ENABLE_BANKING_APP_ID=
# Path to the RSA private key PEM file. Must live on a writable volume (e.g. /data) in read-only containers.
ENABLE_BANKING_PRIVATE_KEY_PATH=/data/enable-banking.pem
# Default production endpoint
ENABLE_BANKING_BASE_URL=https://api.enablebanking.com
# Must match the redirect URL registered in the Enable Banking control panel
ENABLE_BANKING_REDIRECT_URL=https://${DOMAIN}/api/enable-banking/callback
# Session validity (in days) requested from banks; actual maximum depends on the ASPSP
ENABLE_BANKING_SESSION_VALIDITY_DAYS=90